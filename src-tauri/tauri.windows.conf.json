{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FF Downloader",
        "width": 1100,
        "height": 720,
        "minWidth": 400,
        "minHeight": 300,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "center": true,
        "shadow": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --enable-features=msSmoothScrolling --animation-policy=allowed"
      }
    ]
  }
}
